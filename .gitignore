# Compiled assets (auto-generated, don't commit)
shopify/assets/*.min.js
shopify/assets/*.min.css
shopify/assets/*.min.js.map
shopify/assets/*.min.css.map
shopify/assets/.vite/
shopify/assets/manifest.json

# Keep original Shopify assets
!shopify/assets/*.*
shopify/assets/*.min.*

