{% doc %}
  @prompt
    3-columns with image on top and rich text below, editable typography, placement, and container width for both desktop and mobile view, editable container placement, container should be full width with option to adjust, change width adjustment to percentage
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-three-columns-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-three-columns-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width }}%;
    margin-left: {% if block.settings.desktop_alignment == 'left' %}0{% elsif block.settings.desktop_alignment == 'center' %}auto{% else %}auto{% endif %};
    margin-right: {% if block.settings.desktop_alignment == 'right' %}0{% elsif block.settings.desktop_alignment == 'center' %}auto{% else %}auto{% endif %};
    padding: {{ block.settings.desktop_padding_top }}px {{ block.settings.desktop_padding_horizontal }}px {{ block.settings.desktop_padding_bottom }}px;
  }

  .ai-three-columns-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-three-columns-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-three-columns-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .ai-three-columns-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-three-columns-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-three-columns-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-three-columns-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-three-columns-content-{{ ai_gen_id }} h3 {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-three-columns-content-{{ ai_gen_id }} .ai-three-columns-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.text_line_height }};
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-three-columns-container-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_width }}%;
      margin-left: {% if block.settings.mobile_alignment == 'left' %}0{% elsif block.settings.mobile_alignment == 'center' %}auto{% else %}auto{% endif %};
      margin-right: {% if block.settings.mobile_alignment == 'right' %}0{% elsif block.settings.mobile_alignment == 'center' %}auto{% else %}auto{% endif %};
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-three-columns-grid-{{ ai_gen_id }} {
      grid-template-columns: {% if block.settings.mobile_columns == '1' %}1fr{% elsif block.settings.mobile_columns == '2' %}repeat(2, 1fr){% else %}repeat(3, 1fr){% endif %};
      gap: {{ block.settings.mobile_column_gap }}px;
    }

    .ai-three-columns-column-{{ ai_gen_id }} {
      gap: {{ block.settings.mobile_content_gap }}px;
    }

    .ai-three-columns-content-{{ ai_gen_id }} h3 {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-three-columns-content-{{ ai_gen_id }} .ai-three-columns-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }
  }
{% endstyle %}

<div class="ai-three-columns-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-three-columns-container-{{ ai_gen_id }}">
    <div class="ai-three-columns-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign heading_key = 'heading_' | append: i
          assign text_key = 'text_' | append: i
          
          assign column_image = block.settings[image_key]
          assign column_heading = block.settings[heading_key]
          assign column_text = block.settings[text_key]
        %}
        
        <div class="ai-three-columns-column-{{ ai_gen_id }}">
          <div class="ai-three-columns-image-wrapper-{{ ai_gen_id }}">
            {% if column_image %}
              <img
                src="{{ column_image | image_url: width: 800 }}"
                alt="{{ column_image.alt | escape }}"
                loading="lazy"
                width="{{ column_image.width }}"
                height="{{ column_image.height }}"
                class="ai-three-columns-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-three-columns-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          <div class="ai-three-columns-content-{{ ai_gen_id }}">
            {% if column_heading != blank %}
              <h3>{{ column_heading }}</h3>
            {% endif %}
            
            {% if column_text != blank %}
              <div class="ai-three-columns-text-{{ ai_gen_id }}">
                {{ column_text }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

