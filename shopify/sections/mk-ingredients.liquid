{% liquid
  assign section_settings = section.settings
  assign ingredients = product.metafields.custom.key_ingredients.value
  assign image_size = section_settings.image_size

  assign ingredient_count = 0
  if ingredients != blank
    assign ingredient_count = ingredients.count
  endif
%}

{% if ingredient_count > 0 %}
  <section
    class="mk-ingredients"
    style="
      --mk-ingredients-bg-color: {{ section_settings.background_color }};
      --mk-ingredients-column-gap: {{ section_settings.column_gap }}px;
      --mk-ingredients-text-color: {{ section_settings.text_color }};
      --mk-ingredients-image-size: {{ image_size }}px;
      --mk-ingredients-image-radius: {{ section_settings.image_radius }}px;
      --mk-ingredients-padding-top: {{ section_settings.padding_top }}px;
      --mk-ingredients-padding-bottom: {{ section_settings.padding_bottom }}px;
    "
  >
    <div class="mk-ingredients__inner page-width">
      {% if section_settings.heading != blank or section_settings.description != blank %}
        <div class="mk-ingredients__header">
          {% if section_settings.heading != blank %}
            <div class="mk-ingredients__heading">
              {{ section_settings.heading }}
            </div>
          {% endif %}

          {% if section_settings.description != blank %}
            <div class="mk-ingredients__intro">
              {{ section_settings.description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if ingredient_count > 0 %}
        <div class="mk-ingredients__grid mobile:hidden{% if section_settings.desktop_center_justify %} mk-ingredients__grid--desktop-center{% endif %}">
          {% for ingredient in ingredients %}
            {% liquid
              assign ingredient_title = ingredient.title.value | default: ingredient.title
              assign ingredient_description = ingredient.short_description.value | default: ingredient.short_description
              assign ingredient_image = ingredient.image.value | default: ingredient.image
            %}

            <article class="mk-ingredients__card">
              {% if ingredient_image != blank %}
                <div class="mk-ingredients__image-wrap">
                  {{
                    ingredient_image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      class: 'mk-ingredients__image',
                      widths: '200, 300, 400, 500, 600, 800',
                      sizes: '(min-width: 990px) 400px, 70vw'
                  }}
                </div>
              {% endif %}

              {% if ingredient_title != blank %}
                <h3 class="mk-ingredients__title">
                  {{ ingredient_title }}
                </h3>
              {% endif %}

              {% if ingredient_description != blank %}
                <div class="mk-ingredients__description">
                  {{ ingredient_description }}
                </div>
              {% endif %}
            </article>
          {% endfor %}
        </div>

        {% capture mobile_slides %}
          {% for ingredient in ingredients %}
            {% liquid
              assign ingredient_title = ingredient.title.value | default: ingredient.title
              assign ingredient_description = ingredient.short_description.value | default: ingredient.short_description
              assign ingredient_image = ingredient.image.value | default: ingredient.image
            %}

            {% capture mobile_card %}
              <article class="mk-ingredients__card mk-ingredients__card--slide">
                {% if ingredient_image != blank %}
                  <div class="mk-ingredients__image-wrap">
                    {{
                      ingredient_image
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        class: 'mk-ingredients__image',
                        widths: '200, 300, 400, 500, 600, 800',
                        sizes: '100vw'
                    }}
                  </div>
                {% endif %}

                {% if ingredient_title != blank %}
                  <h3 class="mk-ingredients__title">
                    {{ ingredient_title }}
                  </h3>
                {% endif %}

                {% if ingredient_description != blank %}
                  <div class="mk-ingredients__description">
                    {{ ingredient_description }}
                  </div>
                {% endif %}
              </article>
            {% endcapture %}

            {% render 'slideshow-slide', index: forloop.index0, class: 'mk-ingredients__slide', children: mobile_card %}
          {% endfor %}
        {% endcapture %}

        {% capture mobile_controls %}
          {% render 'slideshow-controls', style: 'dots', item_count: ingredient_count, show_arrows: true, class: 'desktop:hidden mk-ingredients__controls' %}
        {% endcapture %}

        {% render 'slideshow',
          ref: 'mkIngredientsMobileSlideshow',
          class: 'desktop:hidden mk-ingredients__carousel',
          slides: mobile_slides,
          controls: mobile_controls,
          show_arrows: false,
          auto_hide_controls: false,
          infinite: false,
          initial_slide: 0,
          slide_count: ingredient_count,
          slideshow_gutters: 'start end',
          style: '--gutter-slide-width: var(--page-margin); --slideshow-gap: 0px;'
        %}
      {% endif %}
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .mk-ingredients {
    background-color: var(--mk-ingredients-bg-color);
    color: var(--mk-ingredients-text-color);
    padding-block-start: var(--mk-ingredients-padding-top);
    padding-block-end: var(--mk-ingredients-padding-bottom);
    padding-inline: var(--page-margin);
  }

  .mk-ingredients__inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .mk-ingredients__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
  }

  .mk-ingredients__heading,
  .mk-ingredients__heading > * {
    margin: 0;
    font-family: Karma, var(--font-heading--family);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
  }

  .mk-ingredients__intro,
  .mk-ingredients__intro > * {
    margin: 0;
    font-family: Karma, var(--font-body--family);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.4;
    text-align: center;
  }

  .mk-ingredients__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--mk-ingredients-column-gap);
    align-items: start;
  }

  @media screen and (min-width: 990px) {
    .mk-ingredients__grid--desktop-center {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-start;
    }

    .mk-ingredients__grid--desktop-center > .mk-ingredients__card {
      width: calc((100% - (2 * var(--mk-ingredients-column-gap))) / 3);
      max-width: calc((100% - (2 * var(--mk-ingredients-column-gap))) / 3);
      flex: 0 0 calc((100% - (2 * var(--mk-ingredients-column-gap))) / 3);
    }
  }

  .mk-ingredients__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    min-width: 0;
  }

  .mk-ingredients__image-wrap {
    width: min(100%, var(--mk-ingredients-image-size));
    aspect-ratio: 1;
    flex: 0 0 auto;
    margin-block-end: 34px;
    border-radius: var(--mk-ingredients-image-radius);
    overflow: hidden;
  }

  .mk-ingredients__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 1;
    transform: rotate(0deg);
  }

  .mk-ingredients__title,
  .mk-ingredients__description {
    margin: 10px 0px;
    font-family: Karma, var(--font-body--family);
    font-size: 18px;
    line-height: 1.4;
    letter-spacing: 0;
    text-align: center;
  }

  .mk-ingredients__title {
    color: inherit;
  }

  .mk-ingredients__title {
    font-weight: 700;
  }

  .mk-ingredients__description {
    margin-block-start: 8px;
    font-weight: 400;
  }

  .mk-ingredients__description > * {
    margin-block: 0;
  }

  .mk-ingredients__carousel {
    display: none;
  }

  .mk-ingredients__carousel slideshow-container {
    background: transparent;
  }

  .mk-ingredients__carousel slideshow-slides {
    gap: 0;
  }

  .mk-ingredients__slide {
    width: 100%;
    flex: 0 0 100%;
    scroll-snap-align: center;
    overflow: visible;
  }

  .mk-ingredients__card--slide {
    width: 100%;
    max-width: none;
    flex-basis: 100%;
    padding-inline: var(--page-margin);
  }

  .mk-ingredients__controls {
    margin-block-start: 20px;
  }

  @media screen and (max-width: 989px) {
    .mk-ingredients__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .mk-ingredients__card {
      max-width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .mk-ingredients__grid {
      display: none;
    }

    .mk-ingredients__carousel {
      display: flex;
    }

    .mk-ingredients__intro,
    .mk-ingredients__intro > *,
    .mk-ingredients__title  {
      font-size: 22px;
    }
    .mk-ingredients__description {
      font-size: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MK Ingredients",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Key Ingredients</p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Image size",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "desktop_center_justify",
      "label": "Center justify items on desktop",
      "default": false
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image radius",
      "min": 0,
      "max": 250,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F7F5F2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "MK Ingredients"
    }
  ]
}
{% endschema %}
